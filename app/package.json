{
  "name": "ecompany-desktop-dev",
  "version": "3.0.0",
  "description": "eCompany AI 虚拟公司 v3.0 桌面应用 — AI团队协作管理",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --x64",
    "pack": "electron-builder --win --x64 --dir"
  },
  "build": {
    "appId": "com.ecompany.desktop.dev",
    "productName": "ECompany Dev",
    "directories": {
      "output": "../dist-desktop-dev"
    },
    "electronDist": "./node_modules/electron/dist",
    "files": [
      "main.js",
      "preload.js",
      "detect-lang.js",
      "package.json"
    ],
    "extraResources": [
      { "from": "../release/backend", "to": "backend" },
      { "from": "../release/frontend/dist", "to": "frontend/dist" },
      { "from": "../release/node.exe", "to": "node.exe" },
      { "from": "../release/AI团队", "to": "AI团队" },
      { "from": "../release/memory", "to": "memory" }
    ],
    "win": {
      "target": ["dir", "nsis"],
      "icon": "../release/logo.jpg"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "ECompany Dev",
      "uninstallDisplayName": "ECompany Dev v3.0 · AI 企业桌面助手"
    }
  },
  "devDependencies": {
    "electron": "^34.0.0",
    "electron-builder": "^25.0.0"
  }
}
